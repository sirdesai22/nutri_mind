# Base URL of the NutriMind backend (required for subscription mode).
# Example for local dev: http://localhost:3000
EXPO_PUBLIC_API_URL=

# Supabase (required for auth and sync)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Razorpay (required for in-app payments)
EXPO_PUBLIC_RAZORPAY_KEY=

# PostHog (analytics)
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google OAuth (for Android/iOS sign-in)
# Android Client ID - from Google Cloud Console with package name: com.sirdesaiexe.nutrimind
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
