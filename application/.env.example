# Base URL of the NutriMind backend (required for subscription mode).
# Example for local dev: http://localhost:3000
EXPO_PUBLIC_API_URL=

# Supabase (required for auth and sync)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Razorpay (required for in-app payments)
EXPO_PUBLIC_RAZORPAY_KEY=

# PostHog (analytics)
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
