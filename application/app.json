{
  "expo": {
    "name": "NutriMind",
    "slug": "calorie_tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/nutrimind.png",
    "scheme": "nutrimind",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sirdesaiexe.nutrimind",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/nutrimind.png",
        "backgroundColor": "#ffffff"
      },

      "package": "com.sirdesaiexe.nutrimind",
      "permissions": [
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/nutrimind.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/nutrimind.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-localization",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "795a7716-22b3-4469-98ca-192e75fb70f7"
      }
    }
  }
}
